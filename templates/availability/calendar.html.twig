{% extends 'base.html.twig' %}

{% block title %}Twoja dostępność{% endblock %}

{% block body %}
<div>
  <div class="container-xl mt-1">
      <div class="row gy-5">
        <div class="col-12">
            <h1>Twoja dostępność</h1>
        </div>
        <div class="col-12 py-2 mb-5 card text-white bg-primary" id="calendar-wrapper">
            {% include 'partials/calendar.html.twig' %}
            <div class="calendar-legend">
              <div class="legend-item">
                  <div class="legend-color" style="background-color: #c8f7c5;"></div>
                  <span>Mogę grać</span>
              </div>
              <div class="legend-item">
                  <div class="legend-color" style="background-color: #f7c5c5;"></div>
                  <span>Nie mogę grać</span>
              </div>
            </div>
        </div>
      </div>
  </div>
</div>
<form id="markMonthForm"
      method="post"
      action="{{ path('availability_mark_month') }}">
    <input type="hidden" name="_token"
           value="{{ csrf_token('mark_month') }}">
</form>
<div class="modal fade" id="confirmMonthModal" tabindex="-1">
  <div class="modal-dialog modal-dialog-centered">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title">Potwierdzenie</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
      </div>
      <div class="modal-body">
        Ten miesiąc ma już ustawioną dostępność.
        Czy chcesz nadpisać ją ponownie?
      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">
          Anuluj
        </button>
        <button type="button" class="btn btn-danger" id="confirmMonthBtn">
          Tak, nadpisz
        </button>
      </div>
    </div>
  </div>
</div>
<div class="modal fade" id="timeModal" tabindex="-1">
  <div class="modal-dialog modal-dialog-centered">
    <div class="modal-content">

      <div class="modal-header">
        <h5 class="modal-title">Ustaw godzinę dostępności</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
      </div>

      <div class="modal-body">
        <div class="d-flex justify-content-center align-items-center ">

          <div class="text-center availability-time-hours">
            <button class="btn btn-sm btn-outline-light time-hour-up">
              <i class="bi bi-chevron-compact-up"></i>
            </button>
            <input type="number" id="hourInput" class="form-control text-center mt-1 mb-1" min="0" max="23" value="19">
            <button class="btn btn-sm btn-outline-light time-hour-down">
              <i class="bi bi-chevron-compact-down"></i>
            </button>
          </div>

          <div class="fs-4">:</div>

          <div class="text-center availability-time-minutes">
            <button class="btn btn-sm btn-outline-light time-minute-up">
              <i class="bi bi-chevron-compact-up"></i>
            </button>
            <input type="number" id="minuteInput" class="form-control text-center mt-1 mb-1" min="0" max="59" step="30" value="0">
            <button class="btn btn-sm btn-outline-light time-minute-down">
              <i class="bi bi-chevron-compact-down"></i>
            </button>
          </div>

        </div>
      </div>

      <div class="modal-footer">
        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">
          Anuluj
        </button>
        <button type="button" class="btn btn-primary" id="saveTimeBtn">
          Zapisz
        </button>
      </div>

    </div>
  </div>
</div>

<script>
  let currentDate = new Date();
  async function loadMonth(year, month) {
    const res = await fetch(`/availability/month?year=${year}&month=${month}`);
    const data = await res.json();

    renderCalendar(data.days);
    updateLabel(year, month);
  }

  function renderCalendar(days) {
    const container = document.getElementById('calendar');

    container.innerHTML = `
      <div class="calendar">
        ${days.map(day => `
          <div class="
            day
            ${day.isCurrentMonth ? '' : 'other-month'}
            ${day.available ? 'available' : 'unavailable'}
          " 
          data-date="${day.date}"
          ${day.isCurrentMonth ? 'data-active=true' : ''}>

            <div class="day-header">${day.dayNumber}</div>

            ${
              day.isCurrentMonth && day.time
                ? `<div class="time">${day.time}</div>`
                : ''
            }

            ${
              day.isCurrentMonth && day.available
                ? `<button class="set-time-btn">Godzina</button>`
                : ''
            }

          </div>
        `).join('')}
      </div>
    `;

    attachListeners();
  }

  function attachListeners() {
    document.querySelectorAll('.day[data-active]').forEach(el => {
      el.addEventListener('click', async (e) => {
        if (e.target.closest('.set-time-btn')) return;

        const date = el.dataset.date;

        const res = await fetch('/availability/toggle', {
          method: 'POST',
          headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
          body: 'date=' + date
        });

        const data = await res.json();

        el.classList.toggle('available', data.available);
        el.classList.toggle('unavailable', !data.available);
      });
    });

    document.querySelectorAll('.set-time-btn').forEach(btn => {
      btn.addEventListener('click', (e) => {
        e.stopPropagation();

        const date = btn.closest('.day').dataset.date;

        window.selectedDate = date;

        const modal = new bootstrap.Modal(document.getElementById('timeModal'));
        modal.show();
      });
    });
  }

  document.getElementById('prevMonth').addEventListener('click', () => {
    currentDate.setMonth(currentDate.getMonth() - 1);
    loadMonth(currentDate.getFullYear(), currentDate.getMonth() + 1);
  });

  document.getElementById('nextMonth').addEventListener('click', () => {
    currentDate.setMonth(currentDate.getMonth() + 1);
    loadMonth(currentDate.getFullYear(), currentDate.getMonth() + 1);
  });

  function updateLabel(year, month) {
    const label = document.getElementById('currentMonthLabel');
    label.textContent = `${year}-${String(month).padStart(2, '0')}`;
  }

  loadMonth(currentDate.getFullYear(), currentDate.getMonth() + 1);
</script>
<style>
.calendar {
  display: grid;
  grid-template-columns: repeat(7, 1fr);
}

.day {
  min-height: 110px;
  padding: 6px;
  border: 1px solid #444;
  position: relative;
}

/* dni z miesiąca */
.day.available {
  background: #c8f7c5;
  cursor: pointer;
}

.day.unavailable {
  background: #f7c5c5;
  cursor: pointer;
}

/* dni spoza miesiąca */
.day.other-month {
  background: #2a2a2a;
  opacity: 0.4;
  pointer-events: none; /* 🔥 najważniejsze */
}

/* button */
.set-time-btn {
  margin-top: 5px;
  width: 100%;
  font-size: 12px;
}
{% endblock %}
